{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://chatbotapp-production-d5b3.up.railway.app/api/$1"
    },
    {
      "source": "/sanctum/csrf-cookie",
      "destination": "https://chatbotapp-production-d5b3.up.railway.app/sanctum/csrf-cookie"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
